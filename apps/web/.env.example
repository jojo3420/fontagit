# 공개 가능한 클라이언트 설정만 적습니다. 실제 값은 배포 환경에 등록하세요.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=

# AdSense 승인 후 발급된 값을 입력합니다.
# client: ca-pub-로 시작하는 게시자 ID
# slot: 숫자로 된 광고 단위 ID
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=

# 카카오 AdFit 광고단위(DAN) ID — AdFit 콘솔(kakao)에서 fontagit.com용으로 발급
# 예: DAN-xxxxxxxxxxxxxxxx (없으면 광고 미노출)
NEXT_PUBLIC_ADFIT_UNIT_HOME=
NEXT_PUBLIC_ADFIT_UNIT_DETAIL=
